{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZeroDrop",
  "version": "0.1.0",
  "identifier": "com.zerodrop.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ZeroDrop",
        "width": 1120,
        "height": 740,
        "minWidth": 920,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
